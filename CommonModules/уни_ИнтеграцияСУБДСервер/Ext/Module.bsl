Процедура ВернутьЗадачуДанныхНаПерегенерацию(Знач ИмяТаблицы, Знач НомерПакета) Экспорт
	
	ЗапросПакетов = Новый Запрос;
	ЗапросПакетов.Текст = 
		"ВЫБРАТЬ

		|	Очередь.ПутьКФайлуПакета КАК ПутьКФайлуПакета
		|ИЗ
		|	РегистрСведений.уни_ОчередьВыгрузкиДанных КАК Очередь

		|ГДЕ
		|	Очередь.ИмяТаблицы = &ИмяТаблицы";
	ЗапросПакетов.УстановитьПараметр("ИмяТаблицы", ИмяТаблицы);
	
	ВыборкаПакетов = ЗапросПакетов.Выполнить().Выбрать();
	Пока ВыборкаПакетов.Следующий() Цикл
		Если ЗначениеЗаполнено(ВыборкаПакетов.ПутьКФайлуПакета) Тогда
			УдалитьФайлы(ВыборкаПакетов.ПутьКФайлуПакета);
		КонецЕсли;
	КонецЦикла;
	
	НачатьТранзакцию();
	Попытка
		НаборЗаписей = РегистрыСведений.уни_ОчередьВыгрузкиДанных.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ИмяТаблицы.Установить(ИмяТаблицы);
		НаборЗаписей.Записать(Истина); 
		
		МенеджерМаркера = РегистрыСведений.уни_ОчередьВыгрузкиДанных.СоздатьМенеджерЗаписи();
		МенеджерМаркера.ИмяТаблицы        = ИмяТаблицы;
		МенеджерМаркера.НомерПакета       = 0;
		МенеджерМаркера.Статус         = Перечисления.уни_СостоянияОчередиВыгрузки.Новый;
		МенеджерМаркера.ДатаРегистрации   = ТекущаяДатаСеанса();
		МенеджерМаркера.КоличествоПопыток = 0;
		МенеджерМаркера.ТекстОшибки       = НСтр("ru = 'Один из файлов пакетов был утерян. Вся серия сброшена и направлена на перегенерацию.'");
		
		МенеджерМаркера.Записать(Истина);
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
	КонецПопытки;
	
КонецПроцедуры


