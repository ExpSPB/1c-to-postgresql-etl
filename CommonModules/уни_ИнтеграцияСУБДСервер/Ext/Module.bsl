#Область ПеречисленияСтатусовИВспомогательныеМетоды
Функция ПолучитьТипДанныхSQL(Знач ОписаниеТипа) Экспорт
	
	МассивТипов = ОписаниеТипа.Типы();
	
	Для Каждого ТекущийТип Из МассивТипов Цикл

		Если ТекущийТип <> Тип("Число") 
			И ТекущийТип <> Тип("Строка") 
			И ТекущийТип <> Тип("Дата") 
			И ТекущийТип <> Тип("Булево") Тогда
			
			Возврат "UUID"; 
		КонецЕсли;
	КонецЦикла;
	
	Если ОписаниеТипа.СодержитТип(Тип("Строка")) Тогда

		Квалификаторы = ОписаниеТипа.КвалификаторыСтроки;
		Если Квалификаторы <> Неопределено И Квалификаторы.Длина > 0 Тогда
			Возврат СтрШаблон("VARCHAR(%1)", Квалификаторы.Длина);
		Иначе
			Возврат "TEXT";
		КонецЕсли;
		
	ИначеЕсли ОписаниеТипа.СодержитТип(Тип("Число")) Тогда
		Квалификаторы = ОписаниеТипа.КвалификаторыЧисла;
		Если Квалификаторы <> Неопределено Тогда
			Длина   = ?(Квалификаторы.Разрядность = 0, 15, Квалификаторы.Разрядность);
			Точность = Квалификаторы.РазрядностьДробнойЧасти;
			Возврат СтрШаблон("NUMERIC(%1,%2)", Длина, Точность);
		Иначе
			Возврат "NUMERIC(15,2)";
		КонецЕсли;
		
	ИначеЕсли ОписаниеТипа.СодержитТип(Тип("Дата")) Тогда
		Возврат "TIMESTAMP"; 
		
	ИначеЕсли ОписаниеТипа.СодержитТип(Тип("Булево")) Тогда
		Возврат "BOOLEAN";
		
	КонецЕсли;
	
	Возврат "VARCHAR(255)"; 
	
КонецФункции

Функция ТекстНижнийРегистр(Знач Значение)
	Возврат НРег(СтрЗаменить(Значение, ".", "_"));
КонецФункции
