

Процедура ЗарегистрироватьТаблицуВОчереди(Знач ПолноеИмяРегистра) Экспорт
	
	НачатьТранзакцию();
	Попытка
		МенеджерЗаписи = РегистрыСведений.уни_ОчередьВыгрузки.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.ИмяТаблицы  = ПолноеИмяРегистра;
		МенеджерЗаписи.Статус = Перечисления.уни_СостоянияОчередиВыгрузки.Новый; 
		МенеджерЗаписи.ДатаРегистрации = ТекущаяДатаСеанса();
		МенеджерЗаписи.КоличествоПопыток = 0;
		
		МенеджерЗаписи.Записать(Истина);
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;
	
КонецПроцедуры

Процедура ЗарегистрироватьТаблицуВОчередиДанных(Знач ПолноеИмяРегистра, Знач НомерПакета, Знач Состояние, Знач ПутьКФайлу = "") Экспорт
	
	НачатьТранзакцию();
	Попытка
		МенеджерЗаписи = РегистрыСведений.уни_ОчередьВыгрузкиДанных.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.ИмяТаблицы        = ПолноеИмяРегистра;
		МенеджерЗаписи.НомерПакета       = НомерПакета;
		
		МенеджерЗаписи.Статус            = Состояние;
		МенеджерЗаписи.ПутьКФайлуПакета  = ПутьКФайлу;
		МенеджерЗаписи.ДатаРегистрации   = ТекущаяДатаСеанса();
		МенеджерЗаписи.КоличествоПопыток = 0;
		МенеджерЗаписи.ТекстОшибки       = "";
		
		МенеджерЗаписи.Записать(Истина);
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;
	
КонецПроцедуры

#Область ДвижокОчереди_Генератор

Процедура СформироватьПакетыМакетовДляВыгрузки() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Очередь.ИмяТаблицы КАК ИмяТаблицы
		|ИЗ
		|	РегистрСведений.уни_ОчередьВыгрузки КАК Очередь
		|ГДЕ
		|	Очередь.Статус = ЗНАЧЕНИЕ(Перечисление.уни_СостоянияОчередиВыгрузки.Новый)
		|УПОРЯДОЧИТЬ ПО
		|	Очередь.ДатаРегистрации ВОЗР";
		
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Если Выборка.Следующий() Тогда
		
		ПутьКФайлу = ПолучитьИмяВременногоФайла("json");
		
		Попытка
			ИзменитьСтатусЗадачи(Выборка.ИмяТаблицы, Перечисления.уни_СостоянияОчередиВыгрузки.ВыполняетсяГенерация);
			
			СгенерироватьJSONСтруктурыВФайл(Выборка.ИмяТаблицы, ПутьКФайлу);
			
			НачатьТранзакцию();
			МенеджерЗаписи = РегистрыСведений.уни_ОчередьВыгрузки.СоздатьМенеджерЗаписи();
			МенеджерЗаписи.ИмяТаблицы = Выборка.ИмяТаблицы;
			МенеджерЗаписи.Прочитать();
			
			Если МенеджерЗаписи.Выбран() Тогда
				МенеджерЗаписи.Статус = Перечисления.уни_СостоянияОчередиВыгрузки.ГотовКОтправке;
				МенеджерЗаписи.ПутьКФайлуПакета = ПутьКФайлу;
				МенеджерЗаписи.Записать(Истина);
			КонецЕсли;
			ЗафиксироватьТранзакцию();
			
		Исключение
			УдалитьФайлы(ПутьКФайлу);
			ЗаписьЖурналаРегистрации("СформироватьПакетыДанныхДляВыгрузки.Ошибка",УровеньЖурналаРегистрации.Ошибка,,,ОписаниеОшибки());
		КонецПопытки;
		
	КонецЕсли;;
	
КонецПроцедуры

Процедура СформироватьПакетыДанныхИзРегистров() Экспорт
	
	ЗапросОчереди = Новый Запрос;
	ЗапросОчереди.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Очередь.ИмяТаблицы КАК ИмяТаблицы,
		|	Очередь.НомерПакета КАК НомерПакета
		|ИЗ
		|	РегистрСведений.уни_ОчередьВыгрузкиДанных КАК Очередь
		|ГДЕ
		|	Очередь.Статус = ЗНАЧЕНИЕ(Перечисление.уни_СостоянияОчередиВыгрузки.Новый)
		|УПОРЯДОЧИТЬ ПО
		|	Очередь.ДатаРегистрации ВОЗР";
		
	Выборка = ЗапросОчереди.Выполнить().Выбрать();
	
	Если Не Выборка.Следующий() Тогда
		Возврат;
	КонецЕсли;
	
	ПолноеИмяРегистра  = Выборка.ИмяТаблицы;
	СтартовыйНомер     = Выборка.НомерПакета;
	
	ИзменитьСтатусЗадачиДанных(ПолноеИмяРегистра, СтартовыйНомер, Перечисления.уни_СостоянияОчередиВыгрузки.ВРаботеГенерацииДанных);
	
	Попытка
		
		ВыгрузитьДанныеРегистраВФайлы(ПолноеИмяРегистра, СтартовыйНомер);
		
		УдалитьСтартовуюЗаписьДанных(ПолноеИмяРегистра);
		
	Исключение
		ЗаписьЖурналаРегистрации("СформироватьПакетыДанныхИзРегистров.Ошибка",УровеньЖурналаРегистрации.Ошибка,,,ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

Процедура ВыгрузитьДанныеРегистраВФайлы(Знач ПолноеИмяРегистра, Знач СтартовыйНомерПакета)
	
	Метаобъект = Метаданные.НайтиПоПолномуИмени(ПолноеИмяРегистра);
	
	МассивПолей = Новый Массив;
	
	СтруктураТипов = Новый Соответствие;
	
	Для Каждого Реквизит Из Метаобъект.СтандартныеРеквизиты Цикл
		Если Реквизит.Имя = "Период" Или Реквизит.Имя = "Регистратор" Тогда
			МассивПолей.Добавить(Реквизит.Имя);
			СтруктураТипов.Вставить(Реквизит.Имя, Реквизит.Тип);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого Измерение Из Метаобъект.Измерения Цикл
		МассивПолей.Добавить(Измерение.Имя);
		СтруктураТипов.Вставить(Измерение.Имя, Измерение.Тип);
	КонецЦикла;
	
	Для Каждого Ресурс Из Метаобъект.Ресурсы Цикл
		МассивПолей.Добавить(Ресурс.Имя);
		СтруктураТипов.Вставить(Ресурс.Имя, Ресурс.Тип); 
	КонецЦикла;
	
	ТекстЗапроса1С = СтрШаблон("ВЫБРАТЬ %1 ИЗ %2 КАК ТаблицаРегистра", СтрСоединить(МассивПолей, ", "), ПолноеИмяРегистра);
	ЗапросДанных   = Новый Запрос(ТекстЗапроса1С);
	ВыборкаДанных  = ЗапросДанных.Выполнить().Выбрать();
	
	ТекущийНомерПакета = СтартовыйНомерПакета + 1;
	СчетчикСтрок       = 0;
	ПакетЗапущен       = Ложь;
	ЗаписьJSON         = Неопределено;
	ПутьКФайлу         = "";
	
	Пока ВыборкаДанных.Следующий() Цикл
		
		Если СчетчикСтрок = 0 Тогда
			ПутьКФайлу = ПолучитьИмяВременногоФайла("json");
			ЗаписьJSON = Новый ЗаписьJSON;
			ЗаписьJSON.ОткрытьФайл(ПутьКФайлу, КодировкаТекста.UTF8, Ложь);
			
			ЗаписьJSON.ЗаписатьНачалоОбъекта();
			ЗаписьJSON.ЗаписатьИмяСвойства("table_name");
			ЗаписьJSON.ЗаписатьЗначение(ТекстНижнийРегистр(Метаобъект.Имя));
			
			ЗаписьJSON.ЗаписатьИмяСвойства("rows");
			ЗаписьJSON.ЗаписатьНачалоМассива();
			ПакетЗапущен = Истина;
		КонецЕсли;
		
		ЗаписатьСтрокуДанныхВJSON(ЗаписьJSON, ВыборкаДанных, МассивПолей, СтруктураТипов);
		
		СчетчикСтрок = СчетчикСтрок + 1;
		
		Если СчетчикСтрок >= 5000 Тогда
			ЗаписьJSON.ЗаписатьКонецМассива();
			ЗаписьJSON.ЗаписатьКонецОбъекта();
			ЗаписьJSON.Закрыть();
			
			ЗарегистрироватьТаблицуВОчередиДанных(ПолноеИмяРегистра, ТекущийНомерПакета, Перечисления.уни_СостоянияОчередиВыгрузки.ГотовКОтправке, ПутьКФайлу);
			
			ТекущийНомерПакета = ТекущийНомерПакета + 1;
			СчетчикСтрок       = 0;
			ПакетЗапущен       = Ложь;
		КонецЕсли;
		
	КонецЦикла;
	
	Если ПакетЗапущен Тогда
		ЗаписьJSON.ЗаписатьКонецМассива();
		ЗаписьJSON.ЗаписатьКонецОбъекта();
		ЗаписьJSON.Закрыть();
		
		ЗарегистрироватьТаблицуВОчередиДанных(ПолноеИмяРегистра, ТекущийНомерПакета, Перечисления.уни_СостоянияОчередиВыгрузки.ГотовКОтправке, ПутьКФайлу);
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаписатьСтрокуДанныхВJSON(ЗаписьJSON, ВыборкаДанных, МассивПолей, СтруктураТипов)
	
	ЗаписьJSON.ЗаписатьНачалоОбъекта();
	
	Для Каждого ИмяПоля Из МассивПолей Цикл
		
		ЗаписьJSON.ЗаписатьИмяСвойства(ТекстНижнийРегистр(ИмяПоля));
		ЗначениеПоля = ВыборкаДанных[ИмяПоля];
		
		Если ЗначениеПоля = NULL Или ЗначениеПоля = Неопределено Тогда
			ЗаписьJSON.ЗаписатьЗначение("");
			Продолжить;
		КонецЕсли;
		
		ОписаниеТипа = СтруктураТипов[ИмяПоля];
		ТипСУБД      = ?(ОписаниеТипа <> Неопределено, ПолучитьТипДанныхSQL(ОписаниеТипа), "TEXT");
		
		Если ТипСУБД = "UUID" Тогда
			
			Если Не ЗначениеЗаполнено(ЗначениеПоля) Тогда
				ЗаписьJSON.ЗаписатьЗначение("00000000-0000-0000-0000-000000000000");
			Иначе
				ЗаписьJSON.ЗаписатьЗначение(Строка(ЗначениеПоля.УникальныйИдентификатор()));
			КонецЕсли;
			
		ИначеЕсли ТипСУБД = "TIMESTAMP" Тогда
			
			СтрокаДатыJSON = ЗаписатьДатуJSON(ЗначениеПоля, ФорматДатыJSON.ISO, ВариантЗаписиДатыJSON.ЛокальнаяДата);
			ЗаписьJSON.ЗаписатьЗначение(СтрокаДатыJSON);
			
		ИначеЕсли Найти(ТипСУБД, "VARCHAR") > 0 Или ТипСУБД = "TEXT" Тогда
			
			ЗаписьJSON.ЗаписатьЗначение(Строка(ЗначениеПоля));
		Иначе
			
			ЗаписьJSON.ЗаписатьЗначение(ЗначениеПоля);
		КонецЕсли;
		
	КонецЦикла;
	
	ЗаписьJSON.ЗаписатьКонецОбъекта();
	
КонецПроцедуры

Процедура СгенерироватьJSONСтруктурыВФайл(Знач ПолноеИмяРегистра, Знач ПутьКФайлу)
	
	Метаобъект = Метаданные.НайтиПоПолномуИмени(ПолноеИмяРегистра);
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.ОткрытьФайл(ПутьКФайлу, КодировкаТекста.UTF8, Ложь); 
	
	ЗаписьJSON.ЗаписатьНачалоОбъекта();
	ЗаписьJSON.ЗаписатьИмяСвойства("table_name");
	ЗаписьJSON.ЗаписатьЗначение(ТекстНижнийРегистр(Метаобъект.Имя));
	
	ЗаписьJSON.ЗаписатьИмяСвойства("columns");
	ЗаписьJSON.ЗаписатьНачалоОбъекта();
	
	Для Каждого Реквизит Из Метаобъект.СтандартныеРеквизиты Цикл
		Если Реквизит.Имя = "Период" Или Реквизит.Имя = "Регистратор" Тогда
			ЗаписьJSON.ЗаписатьИмяСвойства(ТекстНижнийРегистр(Реквизит.Имя));
			ЗаписьJSON.ЗаписатьЗначение(ПолучитьТипДанныхSQL(Реквизит.Тип));
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого Измерение Из Метаобъект.Измерения Цикл
		ЗаписьJSON.ЗаписатьИмяСвойства(ТекстНижнийРегистр(Измерение.Имя));
		ЗаписьJSON.ЗаписатьЗначение(ПолучитьТипДанныхSQL(Измерение.Тип));
	КонецЦикла;
	
	Для Каждого Ресурс Из Метаобъект.Ресурсы Цикл
		ЗаписьJSON.ЗаписатьИмяСвойства(ТекстНижнийРегистр(Ресурс.Имя));
		ЗаписьJSON.ЗаписатьЗначение(ПолучитьТипДанныхSQL(Ресурс.Тип));
	КонецЦикла;
	
	ЗаписьJSON.ЗаписатьКонецОбъекта();
	ЗаписьJSON.ЗаписатьКонецОбъекта();
	ЗаписьJSON.Закрыть();
	
КонецПроцедуры

#КонецОбласти


#Область ДвижокОчереди_Транспорт

Процедура ОтправитьГотовыеПакетыНаШлюз() Экспорт
	
	ЗапросСтруктуры = Новый Запрос;
	ЗапросСтруктуры.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1

		|	Очередь.ИмяТаблицы КАК ИмяТаблицы,
		|	Очередь.ПутьКФайлуПакета КАК ПутьКФайлуПакета,
		|	Очередь.КоличествоПопыток КАК КоличествоПопыток

		|ИЗ
		|	РегистрСведений.уни_ОчередьВыгрузки КАК Очередь
		|ГДЕ

		|	Очередь.Статус = ЗНАЧЕНИЕ(Перечисление.уни_СостоянияОчередиВыгрузки.ГотовКОтправке)
		|	И Очередь.КоличествоПопыток < 5
		|УПОРЯДОЧИТЬ ПО

		|	Очередь.ДатаРегистрации ВОЗР";
		
	ВыборкаСтруктуры = ЗапросСтруктуры.Выполнить().Выбрать();
	
	Если ВыборкаСтруктуры.Следующий() Тогда
		ВыполнитьСетевуюОтправкуПакета(ВыборкаСтруктуры, "/api/create-table", Истина);
		Возврат; 
	КонецЕсли;
	
	ЗапросДанных = Новый Запрос;
	ЗапросДанных.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Очередь.ИмяТаблицы КАК ИмяТаблицы,
		|	Очередь.НомерПакета КАК НомерПакета,

		|	Очередь.ПутьКФайлуПакета КАК ПутьКФайлуПакета,
		|	Очередь.КоличествоПопыток КАК КоличествоПопыток
		|ИЗ

		|	РегистрСведений.уни_ОчередьВыгрузкиДанных КАК Очередь
		|ГДЕ
		|	Очередь.Статус = ЗНАЧЕНИЕ(Перечисление.уни_СостоянияОчередиВыгрузки.ГотовКОтправке)

		|	И Очередь.КоличествоПопыток < 5
		|УПОРЯДОЧИТЬ ПО
		|	Очередь.ДатаРегистрации ВОЗР";
		
	ВыборкаДанных = ЗапросДанных.Выполнить().Выбрать();
	
	Если ВыборкаДанных.Следующий() Тогда
		ВыполнитьСетевуюОтправкуПакета(ВыборкаДанных, "/api/upload-data", Ложь);
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

Процедура ВыполнитьСетевуюОтправкуПакета(Знач ВыборкаОчереди, Знач ЭндпоинтURL, Знач ЭтоСтруктура) Экспорт
	
	ФайлНаДиске = Новый Файл(ВыборкаОчереди.ПутьКФайлуПакета);
	Если Не ФайлНаДиске.Существует() Тогда
		Если ЭтоСтруктура Тогда
			ВернутьЗадачуНаПерегенерацию(ВыборкаОчереди.ИмяТаблицы);
		Иначе
			ВернутьЗадачуДанныхНаПерегенерацию(ВыборкаОчереди.ИмяТаблицы, ВыборкаОчереди.НомерПакета);
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	Попытка
		Если ЭтоСтруктура Тогда
			ИзменитьСтатусЗадачи(ВыборкаОчереди.ИмяТаблицы, Перечисления.уни_СостоянияОчередиВыгрузки.ВРаботеОтправки);
		Иначе
			ИзменитьСтатусЗадачиДанных(ВыборкаОчереди.ИмяТаблицы, ВыборкаОчереди.НомерПакета, Перечисления.уни_СостоянияОчередиВыгрузки.ВРаботеОтправки);
		КонецЕсли;
		
		HTTP = Новый HTTPСоединение("127.0.0.1", 5000);
		ЗапросHTTP = Новый HTTPЗапрос(ЭндпоинтURL);
		
		ЗапросHTTP.УстановитьИмяФайлаТела(ВыборкаОчереди.ПутьКФайлуПакета);
		ЗапросHTTP.Заголовки.Вставить("Content-Type", "application/json");
		
		Ответ = HTTP.ОтправитьДляОбработки(ЗапросHTTP);
		
		Если Ответ.КодСостояния = 200 Тогда
			
			ЗапросHTTP = Неопределено; 
			
			УдалитьФайлы(ВыборкаОчереди.ПутьКФайлуПакета);
			
			Если ЭтоСтруктура Тогда
				ФиксироватьУспешнуюОтправку(ВыборкаОчереди.ИмяТаблицы);
			Иначе
				ФиксироватьУспешнуюОтправкуДанных(ВыборкаОчереди.ИмяТаблицы, ВыборкаОчереди.НомерПакета);
			КонецЕсли;
			
		Иначе
			ТекстОшибкиШлюза = Ответ.ПолучитьТелоКакСтроку();
			ВызватьИсключение СтрШаблон(НСтр("ru = 'Шлюз вернул код %1. Ответ: %2'"), Ответ.КодСостояния, ТекстОшибкиШлюза);
		КонецЕсли;
		
	Исключение

		 Если ЭтоСтруктура Тогда
			ФиксироватьСбойОтправки(ВыборкаОчереди.ИмяТаблицы, ВыборкаОчереди.КоличествоПопыток + 1, ОписаниеОшибки());
		Иначе
